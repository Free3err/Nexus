<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="90dp"
    android:layout_height="90dp"
    android:layout_marginEnd="8dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp"
    app:strokeColor="?attr/colorOutline"
    app:strokeWidth="1dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Photo State View -->
        <ImageView
            android:id="@+id/img_photo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Выбранный снимок"
            android:visibility="gone" />

        <!-- Add Button State View -->
        <LinearLayout
            android:id="@+id/layout_add_button"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="visible"
            android:background="?attr/colorSurfaceVariant">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_input_add"
                app:tint="?attr/colorPrimary"
                android:contentDescription="Добавить фотографии" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Добавить"
                android:textColor="?attr/colorPrimary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Main Photo Badge -->
        <TextView
            android:id="@+id/text_main_badge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="#99000000"
            android:gravity="center"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:text="Главное"
            android:textColor="@android:color/white"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Delete Button -->
        <ImageButton
            android:id="@+id/btn_delete_photo"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="top|end"
            android:layout_margin="4dp"
            android:background="@drawable/bg_delete_circle"
            android:src="@drawable/ic_close"
            android:padding="6dp"
            android:scaleType="fitCenter"
            app:tint="@android:color/white"
            android:contentDescription="Удалить фото"
            android:visibility="gone" />

    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
